@startuml
skinparam style strictuml
skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
hide enum methods


package model #eeaaff{

    class Game {
        - turnNum : Integer
        +<<create>>Game()
        + setPlayerName(name : String)
        + setGrid(width : Integer, height : Integer, islandMode : Boolean)
    }

    class Player {
        - _name : String
        +<<create>>Player(name : String)
        + placeShip(ship : Ship)
        + shoot(cell : Cell, weapon : Weapon)
    }

    class Grid {
        - _width : Integer
        - _height : Integer
        +<<create>>Grid(width : Integer, height : Integer)
        + isOccupied(cell : Cell) : Boolean
        + isHit(cell : Cell) : Boolean
        + placeObject(placeable : Placeable)
        + placeImpact(cell : Cell)
        + shoot(cell : Cell, weapon : Weapon)
    }

    package weapons #dfdf40 {
    abstract Weapon <<abstract>> {
    }
    class Bomb extends Weapon {
    }
    class Missile extends Weapon {
    }
    class Sonar extends Weapon {
    }
    }

    enum PlaceableTypes {
        SHIP
        TRAP
        IMPACT
    }
    abstract Placeable <<abstract>> {
        + getCells() : Cell[*]
        + getType() : PlaceableTypes
    }

    class Impact extends Placeable {
        +<<create>>Impact(cell : Cell)
        + getCells() : Cell[1]
    }

    class Ship extends Placeable {
        + <<create>>Ship(positions : Cell[])
        + getCells() : Cell[*]
        + getLength() : Integer
        + getHitParts() : Boolean[*]
        + isHitParts(position : Cell) : Boolean
        + isTheShipHere(position : Cell) : Boolean
        + isDead() : Boolean
    }

    package traps #ff4040 {
    abstract Trap <<abstract>> extends model.Placeable {
        +<<create>>Trap(cell : Cell)
        + getCells() : Cell[1]
    }
    class Tornado extends Trap {
        +<<create>>Tornado(cell : Cell)
    }
    class BlackHole extends Trap {
        +<<create>>BlackHole(cell : Cell)
    }
    }

    class Cell {
        - _x : Integer
        - _y : Integer
        - _hit : Boolean
        + <<create>>Cell(x : Integer, y : Integer)
        + getX() : Integer
        + getY() : Integer
        + setX(x : Integer)
        + setY(y : Integer)
        + isHit() : Boolean
        + setHit()
    }


}

package controller #6999ff {
}

package view #99ff99 {
}


class Main {
}

Placeable *--> "1\n- _type" PlaceableTypes : "> has for type"

Ship o--> "*\n- #_ positions" Cell : "> has for coordinates"
Impact o--> "1\n- #_ position" Cell : "> has for coordinates"
Trap o--> "1\n- #_ position" Cell : "> has for coordinates"

Grid o--> "*\n- _placedObjects" Placeable : "> contains"
Player o--> "1\n- _grid" Grid : "> has for grid"
Player o--> "*\n- _weaponInventory" Weapon : "> can use theses weapons"
Game *--> "2\n- _players" Player : "> has 2 players"

@enduml
